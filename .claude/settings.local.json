{
  "permissions": {
    "allow": [
      "Bash(npx create-next-app@latest:*)",
      "Bash(npm install:*)",
      "Bash(npm ls:*)",
      "Bash(npx prisma init:*)",
      "Bash(npx prisma generate:*)",
      "Bash(npx tsc:*)",
      "Bash(node:*)",
      "Bash(npx next build:*)",
      "mcp__supabase__apply_migration",
      "Bash(taskkill:*)",
      "Bash(timeout:*)",
      "Bash(npx prisma migrate dev:*)",
      "mcp__context7__query-docs"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/distributorkomputer/.bridgespace/bin/bs-claude-hook.cjs\" user-prompt-submit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/distributorkomputer/.bridgespace/bin/bs-claude-hook.cjs\" stop idle \"Finished working\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/distributorkomputer/.bridgespace/bin/bs-claude-hook.cjs\" notification needs-input \"Needs input\""
          }
        ]
      }
    ]
  }
}
