# Database — local dev values below. For Supabase + Railway connection strings
# (transaction pooler for DATABASE_URL, session pooler for DIRECT_URL) see DEPLOY-RAILWAY.md
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/temanyoga?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/temanyoga?schema=public"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Required behind a reverse proxy (e.g. Railway) so Auth.js v5 trusts the forwarded host.
# Without this, login fails with an UntrustedHost error in production.
AUTH_TRUST_HOST="true"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="temanyoga"
R2_PUBLIC_URL=""

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# WhatsApp (Fonnte)
FONNTE_TOKEN=""

# Resend (Email notifications)
# Create key: https://resend.com/api-keys
# Domain setup: docs/RESEND-SETUP.md
RESEND_API_KEY=""

# Cek Ongkir (api.co.id)
API_CO_ID_KEY=""

# Seed (required in production, optional in development)
ADMIN_SEED_PASSWORD=""
